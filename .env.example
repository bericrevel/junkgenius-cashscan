# ---- Baked into the app at build time (safe to ship; not secrets) ----

# Your deployed Vercel project origin, e.g. https://junkgenius-cashscan.vercel.app
VITE_API_BASE_URL=

# App key sent as X-App-Key. Must match APP_SHARED_KEY on the server.
# Generate:  openssl rand -hex 24
VITE_APP_KEY=

# ---- Set on the Vercel project (Settings > Environment Variables), ----
# ---- NEVER in this file.                                            ----
#
# TWO model providers, split by cost/fit (see README "Why two AI providers"):
#
# GEMINI_API_KEY=...                 (required — powers the photo-scan/identify
#                                      task. Free key: aistudio.google.com)
# ANTHROPIC_API_KEY=sk-ant-...       (required — powers guide/chat/listing/buyer.
#                                      Set a spend cap in the Anthropic console)
# APP_SHARED_KEY=...                 (optional; same value as VITE_APP_KEY above)
# ANTHROPIC_MODEL=claude-sonnet-4-6  (optional override; this is the default)
#
# ---- JunkGenius Pro (Stripe) — carried over unchanged from CashScan ----
# STRIPE_SECRET_KEY=sk_live_...    (or sk_test_... while testing)
# STRIPE_PRICE_MONTHLY=price_...   (the $3.99/mo price id from your dashboard)
# STRIPE_PRICE_ANNUAL=price_...    (the $24/yr price id from your dashboard)
# These three already exist on the live Vercel project — only the two AI keys
# above are new additions for the merge.
#
# FOUNDER_CODE=...                 (optional — owner unlock. Any secret phrase
#                                   you choose. Type it into the app's
#                                   "Restore my Pro" box on any of your devices
#                                   for permanent Pro with no subscription.
#                                   Server-side only; never ships in the APK.)
