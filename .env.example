# ---- Baked into the app at build time (safe to ship; not secrets) ----

# Point this at wherever you deploy /api/claude.ts (a Vercel project).
# e.g. https://junkgenius-cashscan.vercel.app
VITE_API_BASE_URL=

# App key sent as X-App-Key on every request. Must match APP_SHARED_KEY on the
# server. This is a speed bump against drive-by abuse of your proxy, not real
# auth (it ships inside the APK) — the real protections are the proxy's
# task-locked API, rate limiting, and your Anthropic spend cap.
# Generate one with:  openssl rand -hex 24
VITE_APP_KEY=

# ---- Set on the Vercel project (Project Settings > Environment Variables), ----
# ---- NEVER in this file — these must not ship to the device.              ----
#
# ANTHROPIC_API_KEY=sk-ant-...     (required)
# APP_SHARED_KEY=...               (same value as VITE_APP_KEY above; if unset,
#                                   the key check is skipped — dev convenience)
# ANTHROPIC_MODEL=claude-sonnet-4-6  (optional override; this is the default)
#
# ---- CashScan Pro (Stripe) — see README "CashScan Pro" section ----
# STRIPE_SECRET_KEY=sk_live_...    (or sk_test_... while testing)
# STRIPE_PRICE_MONTHLY=price_...   (the $3.99/mo price id from your dashboard)
# STRIPE_PRICE_ANNUAL=price_...    (the $24/yr price id from your dashboard)
